  "remediation_plan": [
    {
      "area": "quota row update",
      "action": "Move quota reservation later or split it into a short atomic transaction so the quota_usage row lock is not held while candidate selection and delivery-history reads run."
    },
    {
      "area": "transaction boundary",
      "action": "Shorten the /next write transaction: perform read-only candidate selection outside the quota row lock, then reserve quota and insert delivery plus selection decision in the smallest possible write section."
    },
    {
      "area": "atomic quota accounting",
      "action": "Keep the ON CONFLICT quota increment atomic, but return immediately after the increment and avoid holding the same transaction through delivery metrics reads."
    },
    {
      "area": "selection decisions",
      "action": "If the shortened transaction is still lock-heavy, make selection_decisions insert cheap or asynchronous after delivery creation is durable."
    },
    {
      "area": "diagnostics",
      "action": "Do not add synchronous diagnostics writes to the /next path; keep lock sampling out-of-band and read-only."
    },
